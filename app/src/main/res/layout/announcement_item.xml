<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#212D40">

        <TextView
            android:id="@+id/tvAnnouncementTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sample Title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/tvAnnouncementMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This is the message body of the announcement."
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvAnnouncementDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Posted: Sep 20, 2025"
            android:textSize="12sp"
            android:paddingTop="6dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>