<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Project1" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/slate_blue_gray</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>

        <item name="android:windowBackground">@color/midnight_blue</item>
        <item name="android:textColorHint">@color/gray_pink</item>
        <item name="android:textColor">@color/white</item>

        <item name="android:textColorPrimary" tools:targetApi="l">?attr/colorOnPrimary</item>
        <item name="alertDialogTheme">@style/MyAlertDialogTheme</item>

        <!-- Customize your theme here. -->
    </style>


    <style name="MyAlertDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <!-- Dialog background -->
        <item name="materialAlertDialogBodyTextStyle">@style/MyDialogBodyText</item>
        <item name="materialAlertDialogTitleTextStyle">@style/MyDialogTitleText</item>
        <item name="android:background">@color/slate_blue_gray</item>

        <!-- Button styles -->
        <item name="buttonBarPositiveButtonStyle">@style/MyDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/MyDialogButton</item>
    </style>

    <!-- Title text -->
    <style name="MyDialogTitleText" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Body text -->
    <style name="MyDialogBodyText" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Button text -->
    <style name="MyDialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/white</item>
    </style>


    <style name="MySpinnerStyle" parent="Widget.AppCompat.Spinner">
    </style>


</resources>