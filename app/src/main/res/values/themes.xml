<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Project1" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/deep_slate_blue</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <item name="android:windowBackground">@color/midnight_blue</item>
        <item name="android:textColorHint">@color/gray_pink</item>
        <item name="android:textColor">@color/white</item>

        <item name="android:textColorPrimary" tools:targetApi="l">?attr/colorOnPrimary</item>

        <item name="alertDialogTheme">@style/MyAlertDialogTheme</item>

        <!-- Customize your theme here. -->
    </style>


    <style name="Theme.Project1NoAction" parent="Theme.Project1">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="MyNav" parent="Theme.Project1">
        <item name="android:background">@color/slate_blue_gray</item>
        <item name="navigationViewStyle">@style/MyNavViewStyle</item>
    </style>

    <style name="MyNavViewStyle" parent="Widget.MaterialComponents.NavigationView">
        <item name="itemTextColor">@color/white</item>
        <item name="itemIconTint">@color/white</item> <!-- optional: makes icons white too -->
    </style>

    <style name="NavMenuText" parent="TextAppearance.AppCompat.Medium">
        <item name="android:textSize">18sp</item> <!-- larger text -->
        <item name="android:textColor">@color/white</item>
        <item name="android:gravity">center_vertical|center_horizontal</item> <!-- vertically and horizontally centered -->
    </style>

    <style name="MyAlertDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <!-- Dialog background -->
        <item name="materialAlertDialogBodyTextStyle">@style/MyDialogBodyText</item>
        <item name="materialAlertDialogTitleTextStyle">@style/MyDialogTitleText</item>
        <item name="android:background">@color/slate_blue_gray</item>

        <!-- Button styles -->
        <item name="buttonBarPositiveButtonStyle">@style/MyDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/MyDialogButton</item>
    </style>

    <!-- Title text -->
    <style name="MyDialogTitleText" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Body text -->
    <style name="MyDialogBodyText" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Button text -->
    <style name="MyDialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/white</item>
    </style>


    <style name="MySpinnerStyle" parent="Widget.AppCompat.Spinner">
        <!-- Text color of selected item -->
        <item name="android:textColor">@color/white</item>

        <!-- Background tint for the spinner -->
        <item name="android:backgroundTint">@color/midnight_blue</item>
        <item name="android:background">@color/midnight_blue</item>

        <!-- Tint for the dropdown arrow -->
        <item name="android:spinnerMode">dropdown</item>
        <item name="android:popupBackground">@color/slate_blue_gray</item>
        <item name="android:dropDownWidth">match_parent</item>
        <item name="android:dropDownHorizontalOffset">0dp</item>
        <item name="android:dropDownVerticalOffset">4dp</item>

        <!-- Padding -->
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>

        <!-- Text appearance -->
        <item name="android:textSize">16sp</item>
        <item name="android:textColorHint">@color/gray_pink</item>

        <!-- Optional: arrow tint for newer API levels -->
        <item name="android:drawableTint">@color/white</item>
    </style>



    <style name="MySpinnerStyle2" parent="Widget.AppCompat.Spinner">
        <!-- Text color of selected item -->
        <item name="android:textColor">@color/white</item>

        <!-- Background tint for the spinner -->
        <item name="android:backgroundTint">@color/slate_blue_gray</item>
        <item name="android:background">@color/slate_blue_gray</item>

        <!-- Tint for the dropdown arrow -->
        <item name="android:spinnerMode">dropdown</item>
        <item name="android:popupBackground">@color/slate_blue_gray</item>
        <item name="android:dropDownWidth">match_parent</item>
        <item name="android:dropDownHorizontalOffset">0dp</item>
        <item name="android:dropDownVerticalOffset">4dp</item>

        <!-- Padding -->
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>

        <!-- Text appearance -->
        <item name="android:textSize">16sp</item>
        <item name="android:textColorHint">@color/gray_pink</item>

        <!-- Optional: arrow tint for newer API levels -->
        <item name="android:drawableTint">@color/white</item>
    </style>

    <style name="MyRadioButton" parent="Widget.MaterialComponents.CompoundButton.RadioButton">
        <item name="android:textColor">@color/white</item>
        <item name="android:buttonTint">@color/slate_blue_gray</item>
        <item name="android:backgroundTint">@color/midnight_blue</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="MyCheckBox" parent="Widget.AppCompat.CompoundButton.CheckBox">
        <item name="android:textColor">@color/white</item>
        <item name="android:buttonTint">@color/slate_blue_gray</item>
        <item name="android:backgroundTint">@color/midnight_blue</item>
    </style>



</resources>